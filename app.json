{
  "expo": {
    "name": "Estufa Pro",
    "slug": "estufa-pro",
    "scheme": "estufapro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#14532d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bruno.estufapro"
    },
    "android": {
      "package": "com.bruno.estufapro",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14532d"
      },
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8987da0d-98d7-473c-ae50-b316546bfe5e"
      }
    },
    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Permitir que o Estufa Pro acesse seus contatos para importar dados de clientes."
        }
      ],
      "expo-font"
    ]
  }
}
