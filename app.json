{
  "expo": {
    "name": "Estufa Pro",
    "slug": "estufa-pro",
    "scheme": "estufapro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#14532d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bruno.estufapro"
    },
    "android": {
      "package": "com.bruno.estufapro",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14532d"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "6cb20ebb-7cfe-4178-9a4f-b644d94feaac"
      }
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
