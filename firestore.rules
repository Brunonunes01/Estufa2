rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function tenantAccessPath(targetTenantId) {
      return /databases/$(database)/documents/users/$(request.auth.uid)/accessible_tenants/$(targetTenantId);
    }

    function isTenantOwner(targetTenantId) {
      return isAuthenticated() && request.auth.uid == targetTenantId;
    }

    function hasSharedTenantAccess(targetTenantId) {
      return isAuthenticated() && exists(tenantAccessPath(targetTenantId));
    }

    // Checa se o usuário logado é dono do tenant ou recebeu acesso válido.
    function hasTenantAccess(targetTenantId) {
      return isTenantOwner(targetTenantId) || hasSharedTenantAccess(targetTenantId);
    }

    function sharedTenantRole(targetTenantId) {
      return get(tenantAccessPath(targetTenantId)).data.role;
    }

    function canWriteTenant(targetTenantId) {
      return isTenantOwner(targetTenantId) ||
        (hasSharedTenantAccess(targetTenantId) && sharedTenantRole(targetTenantId) in ['admin', 'operator']);
    }

    function canDeleteTenant(targetTenantId) {
      return isTenantOwner(targetTenantId);
    }

    function hasTenantField(data) {
      return data.keys().hasAny(['tenantId', 'userId']);
    }

    function resolveTenantId(data) {
      return data.tenantId != null ? data.tenantId : data.userId;
    }

    // Regras globais para coleções tenant-scoped.
    // Exclui users e share_codes para permitir regras mais restritas abaixo.
    match /{collection}/{document=**} {
      allow read: if
        collection != 'users' &&
        collection != 'share_codes' &&
        hasTenantField(resource.data) &&
        hasTenantAccess(resolveTenantId(resource.data));

      allow create: if
        collection != 'users' &&
        collection != 'share_codes' &&
        hasTenantField(request.resource.data) &&
        canWriteTenant(resolveTenantId(request.resource.data));

      allow update: if
        collection != 'users' &&
        collection != 'share_codes' &&
        hasTenantField(resource.data) &&
        hasTenantField(request.resource.data) &&
        resolveTenantId(resource.data) == resolveTenantId(request.resource.data) &&
        canWriteTenant(resolveTenantId(resource.data));

      allow delete: if
        collection != 'users' &&
        collection != 'share_codes' &&
        hasTenantField(resource.data) &&
        canDeleteTenant(resolveTenantId(resource.data));
    }

    // Perfil do usuário
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Acesso compartilhado ao tenant.
      match /accessible_tenants/{tenantId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;

        // Só permite criar vínculo de acesso quando há um share_code válido sendo consumido
        // no mesmo commit (batch/transaction), evitando auto-atribuição arbitrária de tenant.
        allow create: if
          request.auth != null &&
          request.auth.uid == userId &&
          request.resource.data.keys().hasAll(['tenantId', 'role', 'redeemCode', 'permissions']) &&
          request.resource.data.tenantId == tenantId &&
          request.resource.data.role in ['guest', 'operator'] &&
          request.resource.data.redeemCode is string &&
          request.resource.data.permissions is map &&
          request.resource.data.permissions.keys().hasAll(['canRead', 'canWrite', 'canDelete', 'canManageSharing']) &&
          request.resource.data.permissions.canRead is bool &&
          request.resource.data.permissions.canWrite is bool &&
          request.resource.data.permissions.canDelete is bool &&
          request.resource.data.permissions.canManageSharing is bool &&
          exists(/databases/$(database)/documents/share_codes/$(request.resource.data.redeemCode)) &&
          get(/databases/$(database)/documents/share_codes/$(request.resource.data.redeemCode)).data.tenantId == tenantId &&
          get(/databases/$(database)/documents/share_codes/$(request.resource.data.redeemCode)).data.grantRole == request.resource.data.role &&
          get(/databases/$(database)/documents/share_codes/$(request.resource.data.redeemCode)).data.permissions == request.resource.data.permissions &&
          get(/databases/$(database)/documents/share_codes/$(request.resource.data.redeemCode)).data.consumed == false &&
          getAfter(/databases/$(database)/documents/share_codes/$(request.resource.data.redeemCode)).data.consumed == true &&
          getAfter(/databases/$(database)/documents/share_codes/$(request.resource.data.redeemCode)).data.consumedBy == request.auth.uid;

        // Bloqueia update para evitar adulteração de vínculo já concedido.
        allow update: if false;
      }
    }

    // Convites temporários
    match /share_codes/{codeId} {
      allow read: if
        request.auth != null &&
        resource.data.consumed == false &&
        resource.data.expiresAt is timestamp &&
        resource.data.expiresAt > request.time;

      allow create: if
        request.auth != null &&
        request.auth.uid == request.resource.data.createdBy &&
        request.resource.data.tenantId == request.auth.uid &&
        request.resource.data.code == codeId &&
        request.resource.data.code.size() >= 20 &&
        request.resource.data.grantRole in ['guest', 'operator'] &&
        request.resource.data.permissions is map &&
        request.resource.data.permissions.keys().hasAll(['canRead', 'canWrite', 'canDelete', 'canManageSharing']) &&
        request.resource.data.consumed == false &&
        request.resource.data.expiresAt is timestamp;

      // Consumo de código por usuário autenticado.
      allow update: if
        request.auth != null &&
        resource.data.consumed == false &&
        request.resource.data.code == resource.data.code &&
        request.resource.data.tenantId == resource.data.tenantId &&
        request.resource.data.createdBy == resource.data.createdBy &&
        request.resource.data.expiresAt == resource.data.expiresAt &&
        request.resource.data.consumed == true &&
        request.resource.data.consumedBy == request.auth.uid &&
        request.resource.data.consumedAt is timestamp &&
        request.resource.data.updatedAt is timestamp;

      allow delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }
  }
}
